# =============================================================================
# Momentum AI CRM — Variables de entorno (template)
# =============================================================================
# Copiar este archivo a `.env` y rellenar los valores reales.
# `.env` está gitignored — nunca commitear secretos.

# -----------------------------------------------------------------------------
# Supabase — Proyecto v2 (Momentum AI CRM)
# -----------------------------------------------------------------------------
# Dashboard: https://supabase.com/dashboard/project/<PROJECT_REF>
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_PROJECT_REF=<PROJECT_REF>

# Settings → API → Project API keys
SUPABASE_ANON_KEY=<paste-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key>

# Settings → Database → Connection string → URI (con password)
# Formato: postgres://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgres://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=<paste-db-password>

# -----------------------------------------------------------------------------
# Supabase — Proyecto v1 legacy (Casa CRM inmobiliario, sigue corriendo)
# -----------------------------------------------------------------------------
# Solo para scripts de migración cuando v2 esté en pie.
# SUPABASE_V1_URL=https://riznewvshyeqgeajniol.supabase.co
# SUPABASE_V1_PROJECT_REF=riznewvshyeqgeajniol
# SUPABASE_V1_SERVICE_ROLE_KEY=<paste-when-needed>
